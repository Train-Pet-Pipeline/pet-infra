# Global environment variables for Train-Pet-Pipeline.
# Copy to .env in each repo root and fill in actual values.

# Data paths
DATA_ROOT=/data/pet-data
DVC_REMOTE_PATH=/data/dvc-cache

# Teacher API (cloud or local vLLM)
TEACHER_API_URL=http://localhost:8000
TEACHER_API_KEY=

# Inference backend override (auto-detect if unset)
# Valid: cuda, mps, cpu, rknn, api
# INFERENCE_BACKEND=

# Label Studio
LABEL_STUDIO_URL=http://localhost:8080
LABEL_STUDIO_API_KEY=
LABEL_STUDIO_ADMIN_EMAIL=admin@pet-pipeline.local
LABEL_STUDIO_ADMIN_PASSWORD=admin123456
LABEL_STUDIO_DB_PASSWORD=labelstudio

# ClearML experiment tracker (sole tracker since Phase 4 P1-F)
CLEARML_API_HOST=
CLEARML_API_ACCESS_KEY=
CLEARML_API_SECRET_KEY=

# Database
DB_PATH=./data/store.db
